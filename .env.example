# Capital Lab environment template
# Copy to .env.development, .env.staging, or .env.production and replace all CHANGE_ME values.

POSTGRES_DB=capitallab
POSTGRES_USER=capitallab
POSTGRES_PASSWORD=CHANGE_ME
REDIS_PASSWORD=CHANGE_ME

ASPNETCORE_ENVIRONMENT=Production
API_PUBLIC_URL=https://api.example.com
WEB_PUBLIC_URL=https://app.example.com

JWT_ISSUER=https://api.example.com
JWT_AUDIENCE=https://app.example.com
JWT_PRIVATE_KEY_BASE64=CHANGE_ME
JWT_PUBLIC_KEY_BASE64=CHANGE_ME
ENCRYPTION_KEY=CHANGE_ME_32_BYTE_BASE64_OR_PROVIDER_KEY

STORAGE_LOCAL_ROOT=/app/uploads
STORAGE_BASE_URL=https://api.example.com/files
PDF_STORAGE_PATH=/app/uploads/reports

SMTP_HOST=CHANGE_ME
SMTP_PORT=587
SMTP_USERNAME=CHANGE_ME
SMTP_PASSWORD=CHANGE_ME
SMS_PROVIDER_API_KEY=CHANGE_ME
WHATSAPP_PROVIDER_API_KEY=CHANGE_ME
PUSH_PROVIDER_API_KEY=CHANGE_ME

DEMO_BRANCH_COUNT=10
DEMO_DOCTOR_COUNT=50
DEMO_STAFF_COUNT=100
DEMO_PATIENT_COUNT=5000
DEMO_APPOINTMENT_COUNT=50000
DEMO_ORDER_COUNT=50000
DEMO_SAMPLE_COUNT=50000
DEMO_INVOICE_COUNT=100000
DEMO_PAYMENT_COUNT=100000
