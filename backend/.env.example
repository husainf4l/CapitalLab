# Capital Lab — Environment Variables Template
# Copy to .env and fill in values. Never commit .env to version control.

# PostgreSQL
POSTGRES_PASSWORD=your_strong_password_here

# JWT RS256 Keys (generate with: ./generate-rsa-keys.sh)
JWT_PRIVATE_KEY_BASE64=your_base64_encoded_rsa_private_key_pem
JWT_PUBLIC_KEY_BASE64=your_base64_encoded_rsa_public_key_pem

# AES-256 field encryption (generate with: openssl rand -base64 32)
ENCRYPTION_KEY=your_base64_encoded_32_byte_key

# pgAdmin (optional dev tool)
PGADMIN_PASSWORD=admin
