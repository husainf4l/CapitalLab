# Capital Lab — Staging Environment Template
# Copy to .env.staging and replace ALL placeholder values before deploying.
# NEVER commit the real .env.staging to version control.

# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_DB=capitallab_staging
POSTGRES_USER=capitallab
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD_32CHARS

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD

# ── Application ───────────────────────────────────────────────────────────────
ASPNETCORE_ENVIRONMENT=Staging
API_PUBLIC_URL=https://api.capitallab.demo
WEB_PUBLIC_URL=https://app.capitallab.demo

# ── JWT (RSA keys — generate with backend/generate-rsa-keys.sh) ───────────────
JWT_ISSUER=https://api.capitallab.demo
JWT_AUDIENCE=https://app.capitallab.demo
JWT_PRIVATE_KEY_BASE64=CHANGE_ME_RSA_PRIVATE_KEY_BASE64
JWT_PUBLIC_KEY_BASE64=CHANGE_ME_RSA_PUBLIC_KEY_BASE64

# ── Encryption ────────────────────────────────────────────────────────────────
# 32-byte random key, base64 encoded: openssl rand -base64 32
ENCRYPTION_KEY=CHANGE_ME_32_BYTE_BASE64

# ── Storage ───────────────────────────────────────────────────────────────────
STORAGE_LOCAL_ROOT=/app/uploads
STORAGE_BASE_URL=https://api.capitallab.demo/files
PDF_STORAGE_PATH=/app/uploads/reports

# ── Email (SMTP) ──────────────────────────────────────────────────────────────
# Use any transactional email provider (Mailgun, SendGrid, SES, etc.)
SMTP_HOST=smtp.mailgun.org
SMTP_PORT=587
SMTP_USERNAME=CHANGE_ME_SMTP_USERNAME
SMTP_PASSWORD=CHANGE_ME_SMTP_PASSWORD

# ── SMS ───────────────────────────────────────────────────────────────────────
# Provider: Unifonic, Twilio, etc.
SMS_PROVIDER_API_KEY=CHANGE_ME_SMS_API_KEY

# ── WhatsApp ──────────────────────────────────────────────────────────────────
WHATSAPP_PROVIDER_API_KEY=CHANGE_ME_WHATSAPP_API_KEY

# ── Push Notifications (Firebase FCM) ────────────────────────────────────────
PUSH_PROVIDER_API_KEY=CHANGE_ME_FIREBASE_SERVER_KEY

# ── Demo Data Counts (staging-sized dataset) ─────────────────────────────────
DEMO_BRANCH_COUNT=10
DEMO_DOCTOR_COUNT=30
DEMO_STAFF_COUNT=50
DEMO_PATIENT_COUNT=500
DEMO_APPOINTMENT_COUNT=2000
DEMO_ORDER_COUNT=2000
DEMO_SAMPLE_COUNT=2000
DEMO_INVOICE_COUNT=3000
DEMO_PAYMENT_COUNT=2500

# ── Validation Steps ─────────────────────────────────────────────────────────
# After filling in all values, verify no placeholders remain:
#   grep -E 'CHANGE_ME|REPLACE_WITH' .env.staging && echo "FAIL" || echo "OK"
#
# Generate RSA keys:
#   cd backend && bash generate-rsa-keys.sh
#
# Generate encryption key:
#   openssl rand -base64 32
